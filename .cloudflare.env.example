# ──────────────────────────────────────────────────────
# ReclamTrack — Variables de déploiement Cloudflare Pages
# ──────────────────────────────────────────────────────
# ⚠️ Ce fichier est PRIVÉ — ne jamais le pousser sur GitHub !
#    Il est déjà listé dans .gitignore
# ──────────────────────────────────────────────────────

# 1. Votre token API Cloudflare (avec permission "Cloudflare Pages:Edit")
#    Créez-le ici : https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=VOTRE_TOKEN_API_CLOUDFLARE

# 2. Votre Account ID (visible dans le dashboard Cloudflare, colonne droite)
CF_ACCOUNT_ID=VOTRE_ACCOUNT_ID

# 3. Nom du projet Cloudflare Pages (tel que créé dans votre dashboard)
CF_PROJECT_NAME=reclamtrack

# 4. Branche à déployer (main par défaut)
CF_BRANCH=main
